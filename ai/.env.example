# Copy this to .env and fill in your values
# .env is gitignored — never commit real credentials

# ── ERP database (DigiPharm) ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=digipharma_db
DB_USER=root
DB_PASSWORD=your_password_here

# ── Analytics database (DigiPharm AI) ────────────────────────────────────
ANALYTICS_DB_NAME=digipharmai_db

# ── FastAPI service ───────────────────────────────────────────────────────
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_SECRET_KEY=change_this_to_a_random_string

# ── ETL: Pharmacie Galy (remote server via SSH tunnel) ───────────────────
GALY_PHARMACY_ID=1
GALY_CONN_MODE=ssh
GALY_DB_NAME=pharmacie_galy

# SSH access to Galy's server
GALY_SSH_HOST=xxx.xxx.xxx.xxx
GALY_SSH_PORT=22
GALY_SSH_USER=root
GALY_SSH_KEY=/root/.ssh/id_rsa
# OR password auth (leave blank if using key):
GALY_SSH_PASSWORD=

# MySQL credentials ON Galy's server
GALY_REMOTE_DB_HOST=127.0.0.1
GALY_REMOTE_DB_PORT=3306
GALY_REMOTE_DB_USER=root
GALY_REMOTE_DB_PASS=galy_mysql_password

# ── digiMind chatbot (Groq — free tier, OpenAI-compatible) ────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
